# RUN: toy %s -emit=mlir 2>&1 | FileCheck %s

# User defined generic function that operates on unknown shaped arguments
def multiply_transpose(a, b) {
  return transpose(a) * transpose(b);
}

def main() {
  var a<2, 3> = [[1, 2, 3], [4, 5, 6]];
  var b<2, 3> = [1, 2, 3, 4, 5, 6];
  var c = multiply_transpose(a, b);
  var d = multiply_transpose(b, a);
  print(d);
}

# CHECK-LABEL:   toy.func private @multiply_transpose(
# CHECK-SAME:      %[[ARG0:.*]]: tensor<*xf64>,
# CHECK-SAME:      %[[ARG1:.*]]: tensor<*xf64>) -> tensor<*xf64> {
# CHECK:           %[[TRANSPOSE_0:.*]] = toy.transpose(%[[ARG0]] : tensor<*xf64>) to tensor<*xf64>
# CHECK:           %[[TRANSPOSE_1:.*]] = toy.transpose(%[[ARG1]] : tensor<*xf64>) to tensor<*xf64>
# CHECK:           %[[MUL_0:.*]] = toy.mul %[[TRANSPOSE_0]], %[[TRANSPOSE_1]] : tensor<*xf64>
# CHECK:           toy.return %[[MUL_0]] : tensor<*xf64>
# CHECK:         }

# CHECK-LABEL:   toy.func @main() {
# CHECK:           %[[CONSTANT_0:.*]] = toy.constant dense<{{\[\[}}1.000000e+00, 2.000000e+00, 3.000000e+00], [4.000000e+00, 5.000000e+00, 6.000000e+00]]> : tensor<2x3xf64>
# CHECK:           %[[RESHAPE_0:.*]] = toy.reshape(%[[CONSTANT_0]] : tensor<2x3xf64>) to tensor<2x3xf64>
# CHECK:           %[[CONSTANT_1:.*]] = toy.constant dense<[1.000000e+00, 2.000000e+00, 3.000000e+00, 4.000000e+00, 5.000000e+00, 6.000000e+00]> : tensor<6xf64>
# CHECK:           %[[RESHAPE_1:.*]] = toy.reshape(%[[CONSTANT_1]] : tensor<6xf64>) to tensor<2x3xf64>
# CHECK:           %[[GENERIC_CALL_0:.*]] = toy.generic_call @multiply_transpose(%[[RESHAPE_0]], %[[RESHAPE_1]]) : (tensor<2x3xf64>, tensor<2x3xf64>) -> tensor<*xf64>
# CHECK:           %[[GENERIC_CALL_1:.*]] = toy.generic_call @multiply_transpose(%[[RESHAPE_1]], %[[RESHAPE_0]]) : (tensor<2x3xf64>, tensor<2x3xf64>) -> tensor<*xf64>
# CHECK:           toy.print %[[GENERIC_CALL_1]] : tensor<*xf64>
# CHECK:           toy.return
# CHECK:         }
