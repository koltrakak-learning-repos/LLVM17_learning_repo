# RUN: toy %s -opt -emit=mlir 2>&1 | FileCheck %s

def main() {
  var a = [[1, 2, 3], [4, 5, 6]];
  var b<3, 2> = [1, 2, 3, 4, 5, 6];
  var e = a @ b;
  print(e);
}

# CHECK-LABEL:   toy.func @main() {
# CHECK:           %[[CONSTANT_0:.*]] = toy.constant dense<{{\[\[}}1.000000e+00, 2.000000e+00, 3.000000e+00], [4.000000e+00, 5.000000e+00, 6.000000e+00]]> : tensor<2x3xf64>
# CHECK:           %[[CONSTANT_1:.*]] = toy.constant dense<{{\[\[}}1.000000e+00, 2.000000e+00], [3.000000e+00, 4.000000e+00], [5.000000e+00, 6.000000e+00]]> : tensor<3x2xf64>
# CHECK:           %[[MATMUL_0:.*]] = toy.matmul %[[CONSTANT_0]], %[[CONSTANT_1]] : (tensor<2x3xf64>, tensor<3x2xf64>) -> tensor<2x2xf64>
# CHECK:           toy.print %[[MATMUL_0]] : tensor<2x2xf64>
# CHECK:           toy.return
# CHECK:         }
